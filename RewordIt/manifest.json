{
  "manifest_version": 3,
  "name": "RewordIt",
  "version": "1.0",
  "description": "Analyzes text stress levels and suggests a calmer rewrite using Gemini API.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "externally_connectable": {
    "matches": [
      "https://azhan-ali.github.io/*",
      "http://localhost/*"
    ]
  }
}